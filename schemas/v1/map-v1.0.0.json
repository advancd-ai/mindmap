{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://mindmap.example.com/schemas/map-v1.0.0.json",
  "title": "MindMap Schema v1.0.0",
  "description": "Initial mindmap schema format with basic node and edge support",
  "type": "object",
  "required": ["schemaVersion", "schemaFormat", "id", "title", "nodes", "edges", "metadata"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0.0",
      "description": "Schema version identifier"
    },
    "schemaFormat": {
      "type": "string",
      "const": "mindmap-v1",
      "description": "Schema format identifier"
    },
    "id": {
      "type": "string",
      "pattern": "^map_[a-z0-9-]{6,}$",
      "description": "Unique identifier for the map"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120,
      "description": "Map title"
    },
    "metadata": {
      "type": "object",
      "required": ["createdAt", "updatedAt", "version", "author"],
      "properties": {
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Creation timestamp"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Last update timestamp"
        },
        "version": {
          "type": "integer",
          "minimum": 1,
          "description": "Data version number"
        },
        "author": {
          "type": "string",
          "format": "email",
          "description": "Author email address"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 32
          },
          "maxItems": 20,
          "description": "Tags for categorization and search"
        }
      },
      "additionalProperties": false
    },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "label", "x", "y", "w", "h"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^n_[A-Za-z0-9_-]{4,}$",
            "description": "Unique node identifier"
          },
          "label": {
            "type": "string",
            "maxLength": 200,
            "description": "Node label text"
          },
          "x": {
            "type": "number",
            "description": "X coordinate"
          },
          "y": {
            "type": "number",
            "description": "Y coordinate"
          },
          "w": {
            "type": "number",
            "minimum": 20,
            "maximum": 1000,
            "description": "Width"
          },
          "h": {
            "type": "number",
            "minimum": 20,
            "maximum": 1000,
            "description": "Height"
          },
          "backgroundColor": {
            "type": "string",
            "pattern": "^#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3})$",
            "description": "Background color in hex format"
          },
          "collapsed": {
            "type": "boolean",
            "default": false,
            "description": "Whether node is collapsed"
          },
          "embedUrl": {
            "type": "string",
            "format": "uri",
            "description": "Embedded content URL"
          },
          "embedType": {
            "type": "string",
            "enum": ["youtube", "webpage", "image", "pdf"],
            "description": "Type of embedded content"
          }
        },
        "additionalProperties": false
      },
      "maxItems": 5000,
      "description": "Array of nodes in the mindmap"
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "source", "target"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^e_[A-Za-z0-9_-]{4,}$",
            "description": "Unique edge identifier"
          },
          "source": {
            "type": "string",
            "description": "Source node ID"
          },
          "target": {
            "type": "string",
            "description": "Target node ID"
          },
          "label": {
            "type": "string",
            "maxLength": 50,
            "description": "Edge label text"
          }
        },
        "additionalProperties": false
      },
      "description": "Array of edges connecting nodes"
    },
    "viewState": {
      "type": "object",
      "properties": {
        "zoom": {
          "type": "number",
          "minimum": 0.1,
          "maximum": 5.0,
          "default": 1.0,
          "description": "Zoom level"
        },
        "viewBox": {
          "type": "object",
          "properties": {
            "x": { "type": "number", "description": "ViewBox X coordinate" },
            "y": { "type": "number", "description": "ViewBox Y coordinate" },
            "width": { "type": "number", "minimum": 100, "description": "ViewBox width" },
            "height": { "type": "number", "minimum": 100, "description": "ViewBox height" }
          },
          "required": ["x", "y", "width", "height"],
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}

