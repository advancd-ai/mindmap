{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://mindmap.example.com/schemas/map-v2.0.0.json",
  "title": "MindMap Schema v2.0.0",
  "description": "Advanced mindmap schema with 3D support, groups, and collaboration features",
  "type": "object",
  "required": ["schemaVersion", "schemaFormat", "id", "title", "nodes", "edges", "metadata"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "2.0.0",
      "description": "Schema version identifier"
    },
    "schemaFormat": {
      "type": "string",
      "const": "mindmap-v2",
      "description": "Schema format identifier"
    },
    "id": {
      "type": "string",
      "pattern": "^map_[a-z0-9-]{6,}$",
      "description": "Unique identifier for the map"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120,
      "description": "Map title"
    },
    "metadata": {
      "type": "object",
      "required": ["createdAt", "updatedAt", "version", "author"],
      "properties": {
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Creation timestamp"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Last update timestamp"
        },
        "version": {
          "type": "integer",
          "minimum": 1,
          "description": "Data version number"
        },
        "author": {
          "type": "string",
          "format": "email",
          "description": "Author email address"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 32
          },
          "maxItems": 20,
          "description": "Tags for categorization and search"
        },
        "collaborators": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "email": { "type": "string", "format": "email" },
              "role": { "type": "string", "enum": ["viewer", "editor", "admin"] },
              "permissions": {
                "type": "array",
                "items": { "type": "string" }
              }
            },
            "required": ["email", "role"]
          },
          "description": "Collaboration settings"
        },
        "visibility": {
          "type": "string",
          "enum": ["private", "shared", "public"],
          "default": "private",
          "description": "Map visibility level"
        }
      },
      "additionalProperties": false
    },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "label", "position"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^n_[A-Za-z0-9_-]{4,}$",
            "description": "Unique node identifier"
          },
          "label": {
            "type": "string",
            "maxLength": 200,
            "description": "Node label text"
          },
          "position": {
            "type": "object",
            "properties": {
              "x": { "type": "number", "description": "X coordinate" },
              "y": { "type": "number", "description": "Y coordinate" },
              "z": { "type": "number", "default": 0, "description": "Z coordinate for 3D" }
            },
            "required": ["x", "y"],
            "additionalProperties": false
          },
          "dimensions": {
            "type": "object",
            "properties": {
              "w": { "type": "number", "minimum": 20, "maximum": 1000, "description": "Width" },
              "h": { "type": "number", "minimum": 20, "maximum": 1000, "description": "Height" },
              "d": { "type": "number", "minimum": 1, "maximum": 100, "default": 1, "description": "Depth for 3D" }
            },
            "required": ["w", "h"],
            "additionalProperties": false
          },
          "style": {
            "type": "object",
            "properties": {
              "nodeType": {
                "type": "string",
                "enum": ["rect", "circle", "diamond", "hex", "cloud", "capsule", "file", "card", "3d-box", "3d-sphere"],
                "default": "rect"
              },
              "backgroundColor": { "type": "string", "pattern": "^#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3})$" },
              "borderColor": { "type": "string", "pattern": "^#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3})$" },
              "borderWidth": { "type": "number", "minimum": 0, "maximum": 10, "default": 1 },
              "borderRadius": { "type": "number", "minimum": 0, "maximum": 50, "default": 4 },
              "shadow": {
                "type": "object",
                "properties": {
                  "enabled": { "type": "boolean", "default": false },
                  "blur": { "type": "number", "minimum": 0, "maximum": 20, "default": 4 },
                  "offsetX": { "type": "number", "default": 2 },
                  "offsetY": { "type": "number", "default": 2 },
                  "color": { "type": "string", "pattern": "^#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3})$", "default": "#000000" },
                  "opacity": { "type": "number", "minimum": 0, "maximum": 1, "default": 0.3 }
                }
              }
            },
            "additionalProperties": false
          },
          "text": {
            "type": "object",
            "properties": {
              "align": { "type": "string", "enum": ["left", "center", "right"], "default": "center" },
              "verticalAlign": { "type": "string", "enum": ["top", "middle", "bottom"], "default": "middle" },
              "fontSize": { "type": "number", "minimum": 8, "maximum": 72, "default": 14 },
              "fontWeight": { "type": "string", "enum": ["normal", "bold", "100", "200", "300", "400", "500", "600", "700", "800", "900"], "default": "normal" },
              "fontColor": { "type": "string", "pattern": "^#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3})$", "default": "#000000" },
              "fontFamily": { "type": "string", "default": "system-ui, sans-serif" }
            },
            "additionalProperties": false
          },
          "group": {
            "type": "string",
            "description": "Group ID this node belongs to"
          },
          "collapsed": {
            "type": "boolean",
            "default": false,
            "description": "Whether node is collapsed"
          },
          "locked": {
            "type": "boolean",
            "default": false,
            "description": "Whether node is locked from editing"
          },
          "embed": {
            "type": "object",
            "properties": {
              "url": { "type": "string", "format": "uri" },
              "type": { "type": "string", "enum": ["youtube", "webpage", "image", "pdf", "video", "audio"] },
              "thumbnail": { "type": "string", "format": "uri" }
            },
            "required": ["url", "type"],
            "additionalProperties": false
          },
          "animation": {
            "type": "object",
            "properties": {
              "enabled": { "type": "boolean", "default": false },
              "type": { "type": "string", "enum": ["pulse", "rotate", "bounce", "fade"] },
              "duration": { "type": "number", "minimum": 100, "maximum": 5000, "default": 1000 },
              "delay": { "type": "number", "minimum": 0, "maximum": 5000, "default": 0 }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      },
      "maxItems": 10000,
      "description": "Array of nodes in the mindmap"
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "source", "target"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^e_[A-Za-z0-9_-]{4,}$",
            "description": "Unique edge identifier"
          },
          "source": {
            "type": "string",
            "description": "Source node ID"
          },
          "target": {
            "type": "string",
            "description": "Target node ID"
          },
          "label": {
            "type": "string",
            "maxLength": 50,
            "description": "Edge label text"
          },
          "style": {
            "type": "object",
            "properties": {
              "type": { "type": "string", "enum": ["straight", "curved", "bezier", "3d"], "default": "straight" },
              "color": { "type": "string", "pattern": "^#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3})$" },
              "width": { "type": "number", "minimum": 1, "maximum": 10, "default": 2 },
              "dashArray": { "type": "array", "items": { "type": "number" }, "description": "Dash pattern for line" },
              "arrowhead": {
                "type": "object",
                "properties": {
                  "enabled": { "type": "boolean", "default": true },
                  "size": { "type": "number", "minimum": 5, "maximum": 20, "default": 8 },
                  "type": { "type": "string", "enum": ["arrow", "circle", "diamond"], "default": "arrow" }
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          },
          "animation": {
            "type": "object",
            "properties": {
              "enabled": { "type": "boolean", "default": false },
              "type": { "type": "string", "enum": ["flow", "pulse", "dash"], "default": "flow" },
              "speed": { "type": "number", "minimum": 0.1, "maximum": 5.0, "default": 1.0 }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      },
      "description": "Array of edges connecting nodes"
    },
    "groups": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^g_[A-Za-z0-9_-]{4,}$",
            "description": "Unique group identifier"
          },
          "name": {
            "type": "string",
            "maxLength": 100,
            "description": "Group name"
          },
          "color": {
            "type": "string",
            "pattern": "^#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3})$",
            "description": "Group color"
          },
          "collapsed": {
            "type": "boolean",
            "default": false,
            "description": "Whether group is collapsed"
          },
          "position": {
            "type": "object",
            "properties": {
              "x": { "type": "number" },
              "y": { "type": "number" },
              "z": { "type": "number", "default": 0 }
            },
            "required": ["x", "y"],
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      },
      "description": "Array of node groups"
    },
    "viewState": {
      "type": "object",
      "properties": {
        "zoom": {
          "type": "number",
          "minimum": 0.1,
          "maximum": 10.0,
          "default": 1.0,
          "description": "Zoom level"
        },
        "rotation": {
          "type": "object",
          "properties": {
            "x": { "type": "number", "minimum": -180, "maximum": 180, "default": 0 },
            "y": { "type": "number", "minimum": -180, "maximum": 180, "default": 0 },
            "z": { "type": "number", "minimum": -180, "maximum": 180, "default": 0 }
          },
          "additionalProperties": false
        },
        "viewBox": {
          "type": "object",
          "properties": {
            "x": { "type": "number", "description": "ViewBox X coordinate" },
            "y": { "type": "number", "description": "ViewBox Y coordinate" },
            "width": { "type": "number", "minimum": 100, "description": "ViewBox width" },
            "height": { "type": "number", "minimum": 100, "description": "ViewBox height" }
          },
          "required": ["x", "y", "width", "height"],
          "additionalProperties": false
        },
        "perspective": {
          "type": "number",
          "minimum": 100,
          "maximum": 2000,
          "default": 1000,
          "description": "3D perspective distance"
        },
        "camera": {
          "type": "object",
          "properties": {
            "position": {
              "type": "object",
              "properties": {
                "x": { "type": "number", "default": 0 },
                "y": { "type": "number", "default": 0 },
                "z": { "type": "number", "default": 1000 }
              },
              "required": ["x", "y", "z"],
              "additionalProperties": false
            },
            "target": {
              "type": "object",
              "properties": {
                "x": { "type": "number", "default": 0 },
                "y": { "type": "number", "default": 0 },
                "z": { "type": "number", "default": 0 }
              },
              "required": ["x", "y", "z"],
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "collaboration": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false,
          "description": "Whether collaboration is enabled"
        },
        "activeUsers": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "email": { "type": "string", "format": "email" },
              "cursor": {
                "type": "object",
                "properties": {
                  "x": { "type": "number" },
                  "y": { "type": "number" },
                  "z": { "type": "number", "default": 0 }
                },
                "required": ["x", "y"],
                "additionalProperties": false
              },
              "color": { "type": "string", "pattern": "^#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3})$" }
            },
            "required": ["email", "cursor"],
            "additionalProperties": false
          },
          "description": "Currently active users"
        },
        "history": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean", "default": true },
            "retentionDays": { "type": "number", "minimum": 1, "maximum": 365, "default": 30 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}

