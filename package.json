{
  "name": "open-mindmap",
  "version": "0.1.0",
  "description": "Open Mindmap - Mindmap editing SaaS using GitHub as database",
  "private": true,
  "workspaces": [
    "api",
    "frontend"
  ],
  "scripts": {
    "dev:api": "npm run dev --workspace=api",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev": "npm run dev:api & npm run dev:frontend",
    "build": "npm run build --workspaces",
    "validate": "node scripts/validate.mjs",
    "build-index": "node scripts/build-index.mjs",
    "test": "npm test --workspaces"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "prettier": "^3.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}

