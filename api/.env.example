# Open Mindmap API — copy to .env and edit
# Full reference: ../docs/ENVIRONMENT.md
#
# This example uses on-disk Git (GIT_PROVIDER=local) instead of github.

# Server
PORT=8787
NODE_ENV=development

# Google OAuth (not required if DEV_MODE=true)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8787/auth/google/callback
FRONTEND_URL=http://localhost:3000

# Redis
REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD=

# CORS (comma-separated origins)
CORS_ORIGIN=http://localhost:3000

# Public API URL (optional — image links, PDF; else inferred from request)
# API_URL=http://localhost:8787
# PUBLIC_URL=

# Development only — bypasses real auth (never in production)
DEV_MODE=false

# Optional notifications
# DISCORD_WEBHOOK_URL=

# --- Local Git storage ---
GIT_PROVIDER=local
LOCAL_GIT_ROOT=./data/repos
LOCAL_GIT_OWNER=local
# LOCAL_GIT_REPO=
LOCAL_GIT_AUTHOR_NAME=Mindmap Ziin
LOCAL_GIT_AUTHOR_EMAIL=mindmap@ziin.ai

# GitHub API — optional when GIT_PROVIDER=local (not used for map storage)
# GITHUB_TOKEN=
# GITHUB_OWNER=
# GITHUB_ORG=

# GitHub webhooks (POST /webhooks/github)
# GITHUB_WEBHOOK_SECRET=

# PDF / Playwright
# PDF_CACHE_TTL=3600
# PLAYWRIGHT_MAX_BROWSERS=3
# PLAYWRIGHT_MAX_CONTEXTS=5
# PLAYWRIGHT_BROWSERS_PATH=

# Error responses (optional)
# ENVIRONMENT=development
