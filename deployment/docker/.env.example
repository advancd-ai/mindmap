# Docker Compose — copy to .env next to docker-compose.yml (e.g. deployment/docker/.env)
# Full reference: ../../docs/ENVIRONMENT.md
#
# This example uses on-disk Git storage (GIT_PROVIDER=local) instead of GitHub API.

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback

# URLs (API / browser)
FRONTEND_URL=http://localhost:3000
# API_URL=
# PUBLIC_URL=

# CORS (comma-separated)
CORS_ORIGIN=http://localhost:3000

# Redis
REDIS_PASSWORD=

# --- Frontend container (runtime-config.js at start; see docs/ENVIRONMENT.md) ---
# Change these and restart the frontend container — no image rebuild required.
VITE_API_URL=http://localhost:8787
VITE_ADSENSE_ENABLED=true

# Development
DEV_MODE=false

# Optional
# DISCORD_WEBHOOK_URL=

# --- Local Git storage (maps stored under LOCAL_GIT_ROOT) ---
GIT_PROVIDER=local
LOCAL_GIT_ROOT=/data/repos
# Host path mounted into the API container (see docker-compose volumes)
LOCAL_GIT_ROOT_HOST=./data/repos
LOCAL_GIT_OWNER=local
LOCAL_GIT_AUTHOR_NAME=Mindmap Ziin
LOCAL_GIT_AUTHOR_EMAIL=mindmap@ziin.ai
# LOCAL_GIT_REPO=
# LOCAL_GIT_SHELL=git

# GitHub API — not used for map storage when GIT_PROVIDER=local; set if you still need org features elsewhere
# GITHUB_TOKEN=
# GITHUB_OWNER=
# GITHUB_ORG=

# PDF / Playwright
# PLAYWRIGHT_MAX_BROWSERS=3
# PLAYWRIGHT_MAX_CONTEXTS=5
# PDF_CACHE_TTL=3600

# Webhooks (GitHub only)
# GITHUB_WEBHOOK_SECRET=
